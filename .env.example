# ─── Database ────────────────────────────────────────────────────────────────
# Default: SQLite, zero setup. For Postgres see README "Going to production".
DATABASE_URL="file:./prisma/dev.db"

# ─── Auth (Better Auth) ──────────────────────────────────────────────────────
# Any long random string. `openssl rand -base64 32` works.
BETTER_AUTH_SECRET="change-me-to-a-long-random-string"
BETTER_AUTH_URL="http://localhost:3000"

# Optional Google sign-in (both must be set, plus the public flag):
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# NEXT_PUBLIC_ENABLE_GOOGLE="1"

# ─── AI — paste ONE of these and every AI tool switches on ─────────────────
# ANTHROPIC_API_KEY="sk-ant-..."
# OPENAI_API_KEY="sk-..."
# Optional overrides:
# LLM_PROVIDER="anthropic"        # or "openai" (auto-detected from keys if unset)
# LLM_MODEL="claude-sonnet-4-5"   # or "gpt-4o-mini"

# ─── Marketplace data — paste your Etsy keystring and flip the switch ──────
# Get a key at https://www.etsy.com/developers (an app with public scope).
# ETSY_API_KEY="your-etsy-keystring"
# MARKETPLACE_PROVIDER="etsy"     # default "mock" = deterministic demo data

# ─── Billing (optional — app runs free-tier-only without it) ────────────────
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PRICE_BUSINESS="price_..."    # $9.99/mo recurring price ID
# STRIPE_PRICE_ENTERPRISE="price_..."  # $29.99/mo recurring price ID

# ─── Quotas ──────────────────────────────────────────────────────────────────
FREE_DAILY_SEARCHES="3"
BUSINESS_DAILY_SEARCHES="300"

# ─── v2.0: Etsy shop connection (OAuth PKCE) ────────────────────────────────
# Uses the same ETSY_API_KEY. Register this redirect URI in your Etsy app:
# ETSY_REDIRECT_URI="http://localhost:3000/api/etsy/callback"   # defaults to BETTER_AUTH_URL + /api/etsy/callback
# Dedicated key for AES-256-GCM token encryption (falls back to BETTER_AUTH_SECRET):
# ENCRYPTION_KEY="another-long-random-string"

# ─── v2.0: Daily cron (rank tracking snapshots + token refresh) ─────────────
# CRON_SECRET="long-random-string"
# Schedule GET /api/cron/daily with "authorization: Bearer $CRON_SECRET"
# Vercel: {"crons":[{"path":"/api/cron/daily","schedule":"15 3 * * *"}]}

# ─── v2.0: Etsy API guardrails ──────────────────────────────────────────────
ETSY_RATE_LIMIT_RPS="8"
ETSY_DAILY_BUDGET="9500"

# ─── v2.0: Rank-tracking limits per plan ────────────────────────────────────
TRACKED_FREE="2"
TRACKED_BUSINESS="25"
TRACKED_ENTERPRISE="200"

# ─── v2.2: Email (Resend) — alerts, weekly digest, password reset ───────────
# RESEND_API_KEY="re_..."
# EMAIL_FROM="RankForge <alerts@yourdomain.com>"
# Weekly digest cron:  0 6 * * 1  → GET /api/cron/weekly (Bearer CRON_SECRET)

# ─── v2.2: Quotas are PER TOOL per day (RankHero-style) ─────────────────────
# FREE_DAILY_SEARCHES="3"        # per tool
# BUSINESS_DAILY_SEARCHES="300"  # per tool

# ─── v2.5: Supplier Watch (AliExpress & co. price/stock monitoring) ─────────
# Hourly cron:  0 * * * *  → GET /api/cron/supplier (Bearer CRON_SECRET)
# Vercel: {"crons":[{"path":"/api/cron/supplier","schedule":"0 * * * *"}]}
# Watch limits per plan:
WATCHED_FREE="3"
WATCHED_BUSINESS="50"
WATCHED_ENTERPRISE="500"
# Professional-grade fetching (pick ONE; direct fetch is the default fallback):
# 1) Any scraping proxy — template with {url} placeholder:
# SCRAPER_API_TEMPLATE="http://api.scraperapi.com?api_key=YOUR_KEY&url={url}"
# 2) Official AliExpress Affiliate API (portals.aliexpress.com → open platform):
# ALIEXPRESS_APP_KEY=""
# ALIEXPRESS_APP_SECRET=""
# ALIEXPRESS_TRACKING_ID=""

# ─── v2.6: Public-page scraping provider (no Etsy API key needed) ───────────
# Switch every tool to real data parsed from public Etsy pages:
# MARKETPLACE_PROVIDER="scrape"
# Politeness + caching (defaults are conservative):
SCRAPE_RATE_LIMIT_RPS="0.5"     # 1 request / 2s
SCRAPE_CACHE_TTL_MIN="60"       # cache a fetched page for 60 min
# For reliability against Etsy's anti-bot, route through a scraping proxy
# (reuses the same var as Supplier Watch):
# SCRAPER_API_TEMPLATE="http://api.scraperapi.com?api_key=YOUR_KEY&url={url}"

# ─── v2.8: Internal scheduler (self-hosted servers) ─────────────────────────
# With CRON_SECRET set, `npm start` runs all cron jobs in-process automatically:
# supplier watch hourly, rank tracking daily, digest weekly. No crontab needed.
# INTERNAL_CRON="0"                  # disable if you prefer external cron
# SUPPLIER_CHECK_INTERVAL_MIN="60"   # supplier sweep cadence (minimum 10)
