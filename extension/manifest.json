{
  "manifest_version": 3,
  "name": "RankForge for Etsy",
  "version": "1.0.0",
  "description": "2026 title checks, keyword intel, and one-click audits — right on Etsy pages. Free 2026-compliance analysis works offline.",
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "action": { "default_popup": "popup.html", "default_title": "RankForge" },
  "permissions": ["storage"],
  "host_permissions": ["https://www.etsy.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.etsy.com/*"],
      "js": ["title2026.js", "content.js"],
      "css": ["panel.css"],
      "run_at": "document_idle"
    }
  ],
  "background": { "service_worker": "background.js" }
}
