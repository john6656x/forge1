// RankForge вЂ” full persistence layer.
// Default: SQLite (zero-setup, file ./prisma/dev.db). For production Postgres,
// change provider to "postgresql" and set DATABASE_URL вЂ” models are compatible.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ------------------------------------------------ Better Auth core (do not rename fields)
model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // RankForge extras
  plan          String    @default("FREE") // FREE | BUSINESS | ENTERPRISE
  emailAlerts   Boolean   @default(true) // rank-drop alert emails
  emailDigest   Boolean   @default(true) // weekly digest email

  sessions      Session[]
  accounts      Account[]
  searches      Search[]
  favorites     Favorite[]
  projects      Project[]
  usage         UsageDay[]
  subscriptions Subscription[]
  rankSnapshots RankSnapshot[]
  etsyConnection EtsyConnection?
  trackedKeywords TrackedKeyword[]
  experiments Experiment[]
  apiToken ApiToken?
  watchedProducts WatchedProduct[]
  notifications Notification[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

// ------------------------------------------------ Usage & billing
model UsageDay {
  id       String @id @default(cuid())
  userId   String
  day      String // "YYYY-MM-DD" (UTC)
  tool     String @default("all") // per-tool quota (RankHero-style: 3/day per tool on FREE)
  searches Int    @default(0)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, day, tool])
  @@map("usage_day")
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String
  stripeCustomerId     String?
  stripeSubscriptionId String?   @unique
  plan                 String // BUSINESS | ENTERPRISE
  status               String
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("subscription")
}

// ------------------------------------------------ Research data
model Search {
  id        String   @id @default(cuid())
  userId    String
  tool      String // "tags" | "keywords" | "shop" | "listing" | "rank" | ...
  query     String
  location  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("search")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  kind      String // "tag" | "keyword" | "listing" | "shop"
  value     String
  meta      String? // JSON string
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, value])
  @@map("favorite")
}

model Project {
  id        String        @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     ProjectItem[]

  @@index([userId])
  @@map("project")
}

model ProjectItem {
  id        String   @id @default(cuid())
  projectId String
  kind      String // "tags" | "keywords" | "note" | "listing-draft"
  title     String
  payload   String // JSON string
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_item")
}

model RankSnapshot {
  id         String   @id @default(cuid())
  userId     String
  listingRef String // listing URL or ID
  keyword    String
  location   String
  position   Int? // null = not in top 100
  takenAt    DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, listingRef, keyword, takenAt])
  @@map("rank_snapshot")
}

// ------------------------------------------------ v2.0: Etsy OAuth + tracking
model EtsyConnection {
  id              String   @id @default(cuid())
  userId          String   @unique // one connected shop per account (MVP)
  etsyUserId      String
  shopId          String?
  shopName        String?
  accessTokenEnc  String // AES-256-GCM, see src/lib/crypto.ts
  refreshTokenEnc String
  tokenExpiresAt  DateTime
  scopes          String // space-separated
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("etsy_connection")
}

model TrackedKeyword {
  id         String   @id @default(cuid())
  userId     String
  listingRef String
  keyword    String
  location   String   @default("Global")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, listingRef, keyword, location])
  @@index([active])
  @@map("tracked_keyword")
}

model ApiBudget {
  id    String @id @default(cuid())
  day   String @unique // "YYYY-MM-DD"
  count Int    @default(0)

  @@map("api_budget")
}

model AnalysisCache {
  id          String   @id @default(cuid())
  contentHash String   @unique // sha256(task + normalized input)
  task        String
  resultJson  String
  ai          Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("analysis_cache")
}

// ------------------------------------------------ v2.3: experiments tracker
model Experiment {
  id         String   @id @default(cuid())
  userId     String
  listingRef String
  label      String // "Changed title", "New photos", "Price drop", ...
  note       String?
  at         DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, listingRef])
  @@map("experiment")
}

// ------------------------------------------------ v2.4: Chrome extension
model ApiToken {
  id         String    @id @default(cuid())
  userId     String    @unique // one extension token per user (regenerate = rotate)
  tokenHash  String    @unique // sha256 of the bearer token; plaintext never stored
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_token")
}

// ------------------------------------------------ v2.5: supplier watch
model WatchedProduct {
  id            String   @id @default(cuid())
  userId        String
  url           String
  platform      String // "aliexpress" | "generic" | "demo"
  externalId    String?
  title         String?
  imageUrl      String?
  currency      String   @default("USD")
  lastPrice     Float?
  lastStock     String   @default("unknown") // in_stock | out_of_stock | removed | unknown
  alertPct      Float    @default(1) // min % price move that triggers an alert
  status        String   @default("active") // active | paused | error
  failCount     Int      @default(0)
  lastError     String?
  checkedAt     DateTime?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshots     ProductSnapshot[]

  @@unique([userId, url])
  @@index([status])
  @@map("watched_product")
}

model ProductSnapshot {
  id       String   @id @default(cuid())
  watchId  String
  price    Float?
  currency String   @default("USD")
  stock    String   @default("unknown")
  takenAt  DateTime @default(now())
  watch    WatchedProduct @relation(fields: [watchId], references: [id], onDelete: Cascade)

  @@index([watchId, takenAt])
  @@map("product_snapshot")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // price_drop | price_up | sold_out | back_in_stock | removed | watch_error
  title     String
  body      String
  url       String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notification")
}
